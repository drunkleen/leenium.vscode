    "parameter": "#d8e3e0",
    "variable": "#d8e3e0",
    "property": "#59d6c5",
    "enumMember": "#d9c76b",
    "function": "#f08787",
    "method": "#59d6c5",
    "macro": "#f08787",
    "keyword": "#33b8a8",
    "modifier": "#33b8a8",
    "comment": "#718688",
    "string": "#67cf94",
    "number": "#d9c76b",
    "regexp": "#59d6c5",
    "operator": "#a4b4b2",
    "decorator": "#f4a259",
    "event": "#59d6c5",
    "function.defaultLibrary": "#59d6c5",
    "type.defaultLibrary": "#71e4d8",
    "variable.readonly": "#59d6c5",
    "property.readonly": "#59d6c5"
  },
  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "foreground": "#718688"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#33b8a8"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.regexp",
        "constant.other.symbol",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#67cf94"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#d9c76b"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "meta.function",
        "variable.function",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#59d6c5"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable",
        "entity.name.type",
        "variable.parameter",
        "variable.language",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#a4b4b2"
      }
    },
    {
      "scope": [
        "entity.name.type.class",
        "entity.name.type.enum",
        "entity.name.type.interface",
        "entity.name.type.struct",
        "support.type",
        "support.class",
        "support.module",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#71e4d8"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag",
        "entity.other.attribute-name",
        "meta.tag",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#59d6c5"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "operator",
        "punctuation.definition",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#718688"
      }
    },
    {
      "scope": [
        "meta.brace",
        "meta.brace.curly",
        "meta.brace.square",
        "meta.brace.round",
        "meta.delimiter",
        "meta.group",
        "punctuation.section",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#59d6c5"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.italic",
        "markup.bold",
        "markup.list",
        "markup.quote",
        "markup.link",
        "markup.raw",
        "markup.deleted",
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#d8e3e0"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#71e4d8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#33b8a8",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#e16f73"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#67cf94"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#f4a259"
      }
    },
    {
      "scope": [
        "meta.diff.header",
        "meta.diff.range"
      ],
      "settings": {
        "foreground": "#59d6c5"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#e16f73"
      }
    }
  ]
}
